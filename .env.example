# ══════════════════════════════════════════════════════════════
# Potato-Claw — Configuração de Ambiente
# Copie para .env e ajuste conforme necessário.
# ══════════════════════════════════════════════════════════════

# Perfil de modelos: ultra_leve | equilibrado | maximo
NEURON_PERFIL=ultra_leve

# Diretório de dados (padrão: ./data)
# NEURON_DATA_DIR=./data

# Cache
NEURON_CACHE_HABILITADO=true

# ChromaDB — Memória Semântica
NEURON_CHROMADB_TOP_K=6
NEURON_CHROMADB_THRESHOLD=0.62
NEURON_CHROMADB_NIVEL1_THRESHOLD=0.86
NEURON_RAG_MAX_DOCS=4
NEURON_RAG_MAX_CHARS=2200

# Web RAG — Pipeline de busca profunda (Search → Fetch → Convert → Extract)
NEURON_WEB_RAG_MAX_PAGINAS=3
NEURON_WEB_RAG_FETCH_TIMEOUT=8
NEURON_WEB_RAG_MAX_MD_CHARS=6000
NEURON_WEB_RAG_CACHE_TTL=3600

# Contexto
NEURON_CONTEXTO_MAX_MSGS=5

# Warm-up sob demanda (recomendado false em máquinas de 8GB)
NEURON_WARMUP_HABILITADO=false
NEURON_WARMUP_MODELOS=rapido

# Ações locais mutáveis exigem "confirmar:" por padrão
NEURON_AUTO_APROVAR_ACOES_LOCAIS=false

# Logging
# Níveis: DEBUG, INFO, WARNING, ERROR
NEURON_LOG_LEVEL=WARNING
# Atalho para DEBUG (true/false)
# NEURON_DEBUG=false

# API HTTP — Autenticação
# Se definida, requer header X-API-Key em todas as requests.
# Se vazia ou ausente, acesso é livre (modo dev local).
# NEURON_API_KEY=sua-chave-secreta-aqui

# Ollama (se usar host remoto)
# OLLAMA_HOST=http://localhost:11434
